generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id      Int           @id @default(autoincrement())
  name         String
  surname      String
  email        String        @unique
  password     String
  telephone    String?
  address      String?
  admin        Admin?
  drawSessions DrawSession[]
  fateResults  FateResult[]
  orders       Order[]
}

model Order {
  order_id       Int         @id @default(autoincrement())
  user_id        Int
  total_price    Float
  payment_bill   String?
  createOrder    DateTime    @default(now())
  order_status   String[]    @default(["paid"])
  payment_method String      @default("promptpay")
  user           User        @relation(fields: [user_id], references: [user_id])
  orderItems     OrderItem[]
}

model OrderItem {
  orderItem_id    Int         @id @default(autoincrement())
  order_id        Int
  product_id      Int
  result_id       Int?        @unique
  quantity        Int
  price           Float
  tracking_status String[]    @default(["order_received"])
  order           Order       @relation(fields: [order_id], references: [order_id])
  product         Product     @relation(fields: [product_id], references: [product_id])
  fateResult      FateResult? @relation(fields: [result_id], references: [result_id])
}

model Product {
  product_id     Int         @id @default(autoincrement())
  product_name   String
  category       String
  price          Float
  description    String?
  stock_quantity Int
  createdAt      DateTime    @default(now())
  isActive       Boolean     @default(true)
  main_stat      String[]
  orderItems     OrderItem[]
}

model Witch {
  witch_id          Int          @id @default(autoincrement())
  sanctuary_stat    Int
  purity_stat       Int
  telluric_stat     Int
  ethereality_stat  Int
  omniscience_stat  Int
  healing_stat      Int
  wealth_stat       Int
  abundance_stat    Int
  intelligence_stat Int
  creativity_stat   Int
  affection_stat    Int
  passion_stat      Int
  fateResults       FateResult[]
}

model Fate {
  stat_id     Int          @id @default(autoincrement())
  stat_name   String       @unique
  stone       String
  result_des1 String
  result_des2 String
  result_des3 String
  fateResults FateResult[]
}

model FateResult {
  result_id     Int        @id @default(autoincrement())
  user_id       Int
  witch_id      Int
  drawn_stat    String
  stat_result   String
  result        String
  createdAt     DateTime   @default(now())
  special_event Boolean    @default(false)
  all_stats     Json
  lowest_stats  Json
  fate          Fate       @relation(fields: [stat_result], references: [stat_name])
  user          User       @relation(fields: [user_id], references: [user_id])
  witch         Witch      @relation(fields: [witch_id], references: [witch_id])
  orderItem     OrderItem?
}

model DrawSession {
  session_id Int      @id @default(autoincrement())
  user_id    Int
  witch_id   Int
  choices    Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [user_id])
}

model Admin {
  admin_id Int  @id @default(autoincrement())
  user_id  Int  @unique
  user     User @relation(fields: [user_id], references: [user_id])
}
